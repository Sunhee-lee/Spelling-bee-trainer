# Copy to .env.local and fill with your Supabase project values.
# Both are safe to expose to the browser (the publishable/anon key is public).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-only (do NOT prefix with NEXT_PUBLIC_). Optional: enables the /admin
# aggregate stats. Without it, /admin loads for admins but shows no numbers.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
